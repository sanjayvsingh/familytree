DirectoryIndex index.php

# ── Block sensitive directories & files ──────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block .ged / .gedcom files served directly
  RewriteRule \.(ged|gedcom)$ - [F,L]

  # Block access to auth/, cache/, gedcom/ directories
  RewriteRule ^(auth|cache|gedcom)(/|$) - [F,L]
</IfModule>

# ── Bot / scraper blocking ────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|DotBot|MJ12bot|BLEXBot|DataForSeoBot|PetalBot|serpstatbot|ia_archiver|Baiduspider|YandexBot|Sogou|360Spider|HTTrack|WebCopier|SiteSnagger|wget|curl/[0-9]) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ── Compression ───────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/json text/html text/css application/javascript text/javascript
</IfModule>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header unset X-Powered-By
  Header always set X-Robots-Tag "noindex, nofollow"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "no-referrer"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self'; frame-ancestors 'none'"

  # No caching for PHP responses
  <FilesMatch "\.php$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate"
  </FilesMatch>

  # Long-lived cache for static assets (cache-busted by ?v= query strings)
  <FilesMatch "\.(js|css)$">
    Header always set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
</IfModule>
